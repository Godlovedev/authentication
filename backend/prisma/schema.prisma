// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String  @id @default(uuid()) // UUID pour ne pas exposer des IDs séquentiels (sécurité)
  email        String  @unique
  passwordHash String // Stockera le mot de passe haché par Argon2
  firstName    String?
  lastName     String?

  hashedRefreshToken String?

  // Gestion du statut du compte (OWASP Best Practices)
  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(true)

  // Sécurité avancée (2FA)
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean @default(false)

  // Dates d'audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
